<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jérémy Dos Santos — Product Designer & Automation Expert</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@700&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#0066cc',
            background: '#ffffff',
            text: '#1d1d1f',
            grey: '#86868b',
            teal: '#0066cc',
            surface: '#f5f5f7',
            navy: '#1d1d1f',
            cardborder: '#d2d2d7',
          },
          fontFamily: {
            heading: ['-apple-system', 'BlinkMacSystemFont', '"SF Pro Display"', 'system-ui', 'sans-serif'],
            body: ['-apple-system', 'BlinkMacSystemFont', '"SF Pro Text"', 'system-ui', 'sans-serif'],
          },
          borderRadius: {
            card: '24px',
            btn: '9999px',
          },
          letterSpacing: {
            label: '0.05em',
          }
        }
      }
    }
  </script>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", system-ui, sans-serif;
      color: #1d1d1f;
      background-color: #ffffff;
      -webkit-font-smoothing: antialiased;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", system-ui, sans-serif;
      font-weight: 600;
      letter-spacing: -0.02em;
    }
    .label-text {
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    @keyframes text-slide {
      0%, 26.66% { transform: translateY(0%); }
      33.33%, 60% { transform: translateY(-25%); }
      66.66%, 93.33% { transform: translateY(-50%); }
      100% { transform: translateY(-75%); }
    }
    .animate-text-slide {
      animation: text-slide 7.5s cubic-bezier(0.83, 0, 0.17, 1) infinite;
    }

    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-marquee {
      display: flex;
      width: max-content;
      animation: marquee 40s linear infinite;
    }
    .animate-marquee:hover {
      animation-play-state: paused;
    }

    /* Card Hover Glow Effects */
    .rounded-card {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }
    .rounded-card:hover {
      transform: translateY(-6px) !important;
      box-shadow: 0 14px 30px -6px rgba(26, 107, 255, 0.15) !important;
      border-color: rgba(26, 107, 255, 0.3) !important;
    }
    
    #work-carousel .group .rounded-\\[32px\\] {
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }
    #work-carousel .group:hover .rounded-\\[32px\\] {
      transform: translateY(-8px) !important;
      box-shadow: 0 20px 40px -8px rgba(26, 107, 255, 0.25) !important;
      border-color: rgba(26, 107, 255, 0.3) !important;
    }
  </style>
</head>
<body>
  <!-- SECTION: Navigation -->
  <nav class="w-full py-6 px-8 flex justify-between items-center max-w-7xl mx-auto">
    <a href="/" class="font-heading text-xl tracking-tight text-primary transition-colors">Jérémy Dos Santos</a>
    <div class="hidden md:flex gap-8 items-center">
      <a href="/process.html" class="text-grey hover:text-primary transition-colors font-medium">Process</a>
      <a href="/work.html" class="text-grey hover:text-primary transition-colors font-medium">Work</a>
      <a href="/services.html" class="text-grey hover:text-primary transition-colors font-medium">Services</a>
      <a href="/about.html" class="text-grey hover:text-primary transition-colors font-medium">About</a>
      <a href="mailto:jeremyguillaumedossantos@gmail.com" class="bg-primary text-white px-5 py-2.5 rounded-btn font-medium hover:bg-blue-700 transition-colors">Let's Talk</a>
    </div>
  </nav>

  <!-- SECTION: HERO -->
  <section class="min-h-[90vh] flex items-center pt-[100px] pb-20 px-8 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center w-full">
      
      <!-- Left Column (60%) -->
      <div class="lg:col-span-7 flex flex-col items-start text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface text-grey text-sm font-medium mb-8">
          <span class="w-2 h-2 rounded-full bg-teal animate-pulse"></span>
          Available for new projects · Madrid, Spain
        </div>
        
        <h1 class="text-5xl md:text-6xl lg:text-[64px] font-heading font-bold text-text mb-6 tracking-tight leading-[1.1]">
          I turn complex problems into <br class="hidden lg:block" />
          <span class="inline-flex flex-col h-[1.1em] overflow-hidden align-top text-primary">
            <ul class="block animate-text-slide text-left leading-[1.1] m-0 p-0 list-none">
              <li class="h-[1.1em]">elegant solutions.</li>
              <li class="h-[1.1em]">automated workflows.</li>
              <li class="h-[1.1em]">scalable systems.</li>
              <li class="h-[1.1em]" aria-hidden="true">elegant solutions.</li>
            </ul>
          </span>
        </h1>
        
        <p class="text-xl text-grey leading-relaxed mb-10 max-w-2xl">
          AI automation that saves your team hours. UX research that cuts guesswork. Product design that ships.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center gap-4 mb-12 w-full sm:w-auto">
          <a href="mailto:jeremyguillaumedossantos@gmail.com" class="w-full sm:w-auto text-center bg-primary text-white px-8 py-4 rounded-btn font-medium hover:bg-blue-700 transition-colors shadow-sm text-lg">
            Book a Discovery Call
          </a>
          <a href="/work.html" class="w-full sm:w-auto text-center bg-transparent border border-cardborder text-text px-8 py-4 rounded-btn font-medium hover:bg-surface transition-colors text-lg">
            See My Work
          </a>
        </div>
        
        <div class="flex flex-wrap items-center gap-2 text-sm text-grey font-medium">
          <span>Trusted by teams in 🇫🇷 🇩🇪 🇪🇸 🇬🇧 🇵🇹</span>
          <span class="hidden sm:inline">·</span>
          <span>4 languages</span>
          <span class="hidden sm:inline">·</span>
          <span>6+ years</span>
        </div>
      </div>

      <!-- Right Column (40%) -->
      <div class="lg:col-span-5 w-full flex flex-col gap-6 relative" style="perspective: 1000px;" id="hero-scroll-container">
        <!-- Abstract card/dashboard placeholder -->
        <div id="hero-scroll-card" class="w-full aspect-[4/3] bg-[#222222] rounded-[30px] border-4 border-[#6C6C6C] p-2 md:p-4 relative overflow-hidden flex items-center justify-center shadow-2xl transition-transform duration-75 ease-out origin-bottom" style="transform: rotateX(20deg) scale(1.05); box-shadow: 0 0 #0000004d, 0 9px 20px #0000004a, 0 37px 37px #00000042, 0 84px 50px #00000026, 0 149px 60px #0000000a, 0 233px 65px #00000003;">
          <div class="h-full w-full overflow-hidden rounded-2xl bg-zinc-900 relative flex flex-col items-center justify-center">
            <!-- Background Elements -->
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.05)_0%,transparent_70%)]"></div>
            
            <div class="text-center mb-6 relative z-10">
              <h3 class="text-white text-xl md:text-3xl font-bold mb-2">Proven Track Record</h3>
              <p class="text-zinc-400 text-xs md:text-sm">Delivering excellence across the globe</p>
            </div>

            <!-- Marquee Container -->
            <div class="w-full overflow-hidden relative z-10">
              <!-- Fade masks -->
              <div class="absolute left-0 top-0 bottom-0 w-12 md:w-24 bg-gradient-to-r from-zinc-900 to-transparent z-20 pointer-events-none"></div>
              <div class="absolute right-0 top-0 bottom-0 w-12 md:w-24 bg-gradient-to-l from-zinc-900 to-transparent z-20 pointer-events-none"></div>
              
              <div class="animate-marquee flex gap-4 py-2" style="animation-duration: 25s;">
                <!-- Group 1 -->
                <div class="flex items-center gap-3 bg-zinc-800/80 border border-zinc-700/50 rounded-xl p-3 md:p-4 backdrop-blur-sm shrink-0">
                  <div class="w-8 h-8 rounded-full bg-green-500/20 flex items-center justify-center text-green-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  </div>
                  <div>
                    <div class="text-white font-semibold text-xs md:text-sm">Upwork Top Rated Plus</div>
