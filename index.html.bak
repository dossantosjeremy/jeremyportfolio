              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- SECTION: LOGO STRIP -->
  <section class="bg-surface h-auto md:h-[80px] py-6 md:py-0 border-y border-cardborder flex items-center mb-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-8 w-full flex flex-col md:flex-row items-center gap-8">
      <div class="text-[11px] font-medium uppercase tracking-label text-grey whitespace-nowrap shrink-0">
        Collaborated with teams at
      </div>
      <div class="relative w-full overflow-hidden flex [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
        <div class="animate-marquee flex items-center gap-12 px-6">
          <div class="h-8 w-24 bg-gray-300 rounded-full opacity-50 shrink-0"></div>
          <div class="h-8 w-24 bg-gray-300 rounded-full opacity-50 shrink-0"></div>
          <div class="h-8 w-24 bg-gray-300 rounded-full opacity-50 shrink-0"></div>
          <div class="h-8 w-24 bg-gray-300 rounded-full opacity-50 shrink-0"></div>
          <div class="h-8 w-24 bg-gray-300 rounded-full opacity-50 shrink-0"></div>
          <div class="h-8 w-24 bg-gray-300 rounded-full opacity-50 shrink-0"></div>
          <!-- Duplicates -->
          <div class="h-8 w-24 bg-gray-300 rounded-full opacity-50 shrink-0"></div>
          <div class="h-8 w-24 bg-gray-300 rounded-full opacity-50 shrink-0"></div>
          <div class="h-8 w-24 bg-gray-300 rounded-full opacity-50 shrink-0"></div>
